#include <stdio.h>

int main() {
    int n, bt[10], p[10], wt[10], tat[10], i, j;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Burst Time and Priority of P%d: ", i + 1);
        scanf("%d%d", &bt[i], &p[i]);
    }

    // Sort by priority
    for(i = 0; i < n - 1; i++)
        for(j = i + 1; j < n; j++)
            if(p[i] > p[j]) {
                int t;
                t = p[i]; p[i] = p[j]; p[j] = t;
                t = bt[i]; bt[i] = bt[j]; bt[j] = t;
            }

    wt[0] = 0;
    for(i = 1; i < n; i++)
        wt[i] = wt[i - 1] + bt[i - 1];

    printf("\nProcess\tBT\tPriority\tWT\tTAT\n");
    for(i = 0; i < n; i++) {
        tat[i] = wt[i] + bt[i];
        printf("P%d\t%d\t%d\t\t%d\t%d\n", i + 1, bt[i], p[i], wt[i], tat[i]);
    }

    return 0;
}
